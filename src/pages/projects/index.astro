---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects', ({ data }) => !data.draft);

// Sort: newest first by year
const sortedProjects = allProjects.sort((a, b) => (b.data.year ?? 0) - (a.data.year ?? 0));

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Projects — j2y.dev',
  url: 'https://j2y.dev/projects/',
  itemListElement: sortedProjects.map((p, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    url: `https://j2y.dev/projects/${p.id}/`,
    name: p.data.title,
  })),
};
---

<BaseLayout
  title="Projects"
  description="Personal and open-source projects by Alexandre Joly — side projects, experiments, tools I've built for fun."
  structuredData={structuredData}
>
  <div class="max-w-4xl mx-auto px-6 py-16">
    <header class="mb-12">
      <h1 class="text-3xl font-bold tracking-tight text-zinc-900 dark:text-zinc-100 mb-3">
        Projects
      </h1>
      <p class="text-zinc-600 dark:text-zinc-400 max-w-xl">
        The personal stuff. Side projects, open source, experiments. What I build when no one's paying me to.
      </p>
    </header>

    <div class="grid sm:grid-cols-2 gap-4">
      {sortedProjects.map((item) => (
        <ProjectCard
          title={item.data.title}
          description={item.data.description}
          stack={item.data.stack}
          href={`/projects/${item.id}/`}
          status={item.data.status}
          url={item.data.url}
          github={item.data.github}
        />
      ))}
    </div>
  </div>
</BaseLayout>
