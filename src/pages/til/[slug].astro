---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('til', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const { title, date, tags, description } = post.data;

// Auto-generate description from body text if not explicitly set
const metaDescription = description ?? (() => {
  const raw = (post.body ?? '').replace(/```[\s\S]*?```/g, '').replace(/[#*`_\[\]]/g, '').trim();
  const excerpt = raw.slice(0, 155).trim();
  return excerpt.length > 0 ? (excerpt.length < (post.body ?? '').length ? excerpt + '…' : excerpt) : `TIL: ${title}`;
})();

const formattedDate = date.toLocaleDateString('en-CH', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const isoDate = date.toISOString();

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'BlogPosting',
    headline: title,
    datePublished: isoDate,
    dateModified: isoDate,
    description: metaDescription,
    author: {
      '@type': 'Person',
      '@id': 'https://j2y.dev/#alex',
      name: 'Alexandre Joly',
      url: 'https://j2y.dev/about',
    },
    publisher: {
      '@type': 'Person',
      name: 'Alexandre Joly',
      url: 'https://j2y.dev',
    },
    url: `https://j2y.dev/til/${post.id}/`,
    mainEntityOfPage: `https://j2y.dev/til/${post.id}/`,
    keywords: tags.join(', '),
    isPartOf: {
      '@type': 'Blog',
      name: 'j2y.dev TIL',
      url: 'https://j2y.dev/til',
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      {
        '@type': 'ListItem',
        position: 1,
        name: 'TIL',
        item: 'https://j2y.dev/til',
      },
      {
        '@type': 'ListItem',
        position: 2,
        name: title,
        item: `https://j2y.dev/til/${post.id}/`,
      },
    ],
  },
];
---

<BaseLayout
  title={title}
  description={metaDescription}
  ogTitle={`${title} — j2y.dev/til`}
  ogType="article"
  structuredData={structuredData}
>
  <div class="max-w-4xl mx-auto px-6 py-16">
    <!-- Breadcrumb -->
    <nav class="mb-8 text-sm text-zinc-500 dark:text-zinc-500">
      <a href="/til" class="hover:text-zinc-900 dark:hover:text-zinc-100 transition-colors">TIL</a>
      <span class="mx-2">/</span>
      <span class="text-zinc-900 dark:text-zinc-100 truncate">#{post.id}</span>
    </nav>

    <!-- Header -->
    <header class="mb-10">
      <time
        datetime={isoDate}
        class="font-mono text-sm text-zinc-500 dark:text-zinc-500 block mb-3"
      >
        {formattedDate}
      </time>
      <h1 class="text-2xl sm:text-3xl font-bold tracking-tight text-zinc-900 dark:text-zinc-100 font-mono mb-4 leading-snug">
        {title}
      </h1>
      <div class="flex flex-wrap gap-1.5">
        {tags.map((tag) => (
          <span class="stack-tag px-2 py-0.5 bg-zinc-100 dark:bg-zinc-800 text-zinc-500 dark:text-zinc-400 rounded text-xs">
            #{tag}
          </span>
        ))}
      </div>
    </header>

    <!-- Content -->
    <div class="prose prose-zinc dark:prose-invert max-w-none
      prose-headings:tracking-tight prose-headings:font-mono
      prose-h2:text-xl prose-h2:font-semibold prose-h2:mt-10 prose-h2:mb-4
      prose-p:text-zinc-600 dark:prose-p:text-zinc-400 prose-p:leading-relaxed
      prose-strong:text-zinc-900 dark:prose-strong:text-zinc-100 prose-strong:font-semibold
      prose-code:font-mono prose-code:text-zinc-700 dark:prose-code:text-zinc-300 prose-code:bg-zinc-100 dark:prose-code:bg-zinc-800 prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded
      prose-pre:bg-zinc-900 prose-pre:text-zinc-100 prose-pre:border-none
      [&_pre_code]:bg-transparent [&_pre_code]:p-0 [&_pre_code]:text-inherit
      prose-li:text-zinc-600 dark:prose-li:text-zinc-400
      prose-a:text-blue-600 dark:prose-a:text-blue-400 prose-a:no-underline hover:prose-a:underline
    ">
      <Content />
    </div>

    <!-- Back link -->
    <div class="mt-16 pt-8 border-t border-zinc-200 dark:border-zinc-800">
      <a
        href="/til"
        class="inline-flex items-center gap-2 text-sm text-zinc-500 hover:text-zinc-900 dark:hover:text-zinc-100 transition-colors"
      >
        ← All TIL posts
      </a>
    </div>
  </div>
</BaseLayout>
