---
import socialsData from '../content/socials.json';

const year = new Date().getFullYear();
const socials = socialsData.map(s => ({
  href: s.href,
  label: s.platform,
  rel: s.rel || undefined,
}));
---

<footer class="border-t border-zinc-200 dark:border-zinc-800 mt-24">
  <div class="max-w-4xl mx-auto px-6 py-12">
    <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-6">
      <!-- Left: name + copyright -->
      <div>
        <a href="/" class="font-mono font-bold text-zinc-900 dark:text-zinc-100 hover:text-blue-600 dark:hover:text-blue-400 transition-colors">
          j2y.dev
        </a>
        <p class="mt-1 text-sm text-zinc-500 dark:text-zinc-500">
          © {year} Alexandre Joly
        </p>
      </div>

      <!-- Right: socials + email -->
      <div class="flex flex-col items-start sm:items-end gap-3">
        <div class="flex items-center gap-4 flex-wrap">
          {socials.map(({ href, label, rel }) => (
            <a
              href={href}
              rel={rel ? `${rel} noopener noreferrer` : 'noopener noreferrer'}
              target="_blank"
              class="text-sm text-zinc-500 hover:text-zinc-900 dark:hover:text-zinc-100 transition-colors"
            >
              {label}
            </a>
          ))}
        </div>
        <a
          href="mailto:alexandre@j2y.dev"
          class="text-sm text-zinc-500 hover:text-zinc-900 dark:hover:text-zinc-100 transition-colors font-mono"
        >
          alexandre@j2y.dev
        </a>
      </div>
    </div>
  </div>
</footer>
