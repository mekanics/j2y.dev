---
const clients = [
  // Big / most recognisable first
  { name: 'UBS AG',               logo: '/logos/ubs.svg' },
  { name: 'Procter & Gamble',     logo: '/logos/procter-gamble.svg' },
  { name: 'Deutsche Telekom',     logo: '/logos/deutsche-telekom.svg' },
  { name: 'Schweiz Tourismus',    logo: '/logos/schweiz-tourismus.svg' },
  { name: 'Migros',               logo: '/logos/migros.svg' },
  { name: 'ewz',                  logo: '/logos/ewz.svg' },
  { name: 'Bühler AG',            logo: '/logos/buhler.svg' },
  // Rest alphabetically
  { name: 'Alpiq Digital AG',     logo: '/logos/alpiq.svg' },
  { name: 'Biomed AG',            logo: '/logos/biomed.svg' },
  { name: 'Canton of Thurgau',    logo: '/logos/canton-thurgau.svg' },
  { name: 'dreipol GmbH',         logo: '/logos/dreipol.svg' },
  { name: 'EBP Schweiz AG',       logo: '/logos/ebp.svg' },
  { name: 'Feller AG',            logo: '/logos/feller.svg' },
  { name: 'mygrid AG',            logo: '/logos/mygrid.svg' },
  { name: 'originate GmbH',       logo: '/logos/originate.svg' },
  { name: 'Reproad AG',           logo: '/logos/reproad.svg' },
  { name: 'Spühl GmbH',           logo: '/logos/spuehl.svg' },
];
---

<section class="max-w-5xl mx-auto px-6 py-10">
  <p class="text-xs font-medium tracking-widest text-zinc-400 dark:text-zinc-500 uppercase text-center mb-8">
    Companies I've worked with
  </p>

  <div class="flex flex-wrap items-center justify-center gap-6 sm:gap-8">
    {clients.map(({ name, logo }) => (
      <img
        src={logo}
        alt={name}
        title={name}
        class="logo-item h-7 sm:h-8 w-auto"
        loading="lazy"
        decoding="async"
      />
    ))}
  </div>
</section>

<style>
  .logo-item {
    filter: grayscale(1) opacity(0.45);
    transition: filter 0.25s ease;
  }

  .logo-item:hover {
    filter: grayscale(0) opacity(1);
  }

  /* Slightly higher hover opacity in dark mode */
  :global(.dark) .logo-item {
    filter: grayscale(1) opacity(0.4);
  }

  :global(.dark) .logo-item:hover {
    filter: grayscale(0) opacity(0.95);
  }
</style>
