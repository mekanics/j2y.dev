---
interface Props {
  title: string;
  date: Date;
  tags: string[];
  href: string;
  excerpt?: string;
}

const { title, date, tags, href, excerpt } = Astro.props;

const formattedDate = date.toLocaleDateString('en-CH', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});

const isoDate = date.toISOString();
---

<article class="group flex flex-col sm:flex-row sm:items-start gap-3 py-4 border-b border-zinc-100 dark:border-zinc-800/60 last:border-0">
  <!-- Date -->
  <time
    datetime={isoDate}
    class="font-mono text-xs text-zinc-400 dark:text-zinc-600 shrink-0 sm:w-28 sm:pt-0.5"
  >
    {formattedDate}
  </time>

  <!-- Content -->
  <div class="flex-1 min-w-0">
    <a
      href={href}
      class="block font-mono text-sm font-medium text-zinc-900 dark:text-zinc-100 hover:text-orange-600 dark:hover:text-blue-400 transition-colors leading-snug mb-2"
    >
      {title}
    </a>
    {excerpt && (
      <p class="text-sm text-zinc-600 dark:text-zinc-400 leading-relaxed mb-2 line-clamp-2">
        {excerpt}
      </p>
    )}
    <div class="flex flex-wrap gap-1.5">
      {tags.map((tag) => (
        <span class="stack-tag px-1.5 py-0.5 bg-zinc-100 dark:bg-zinc-800/80 text-zinc-500 dark:text-zinc-500 rounded text-xs">
          #{tag}
        </span>
      ))}
    </div>
  </div>
</article>
