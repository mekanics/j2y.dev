---
interface Props {
  title: string;
  client?: string;
  role?: string;
  description: string;
  stack: string[];
  href: string;
  date?: string;
  status?: string;
  url?: string;
  github?: string;
}

const { title, client, role, description, stack, href, date, status, url, github } = Astro.props;

const statusColors: Record<string, string> = {
  live: 'text-green-600 dark:text-green-400 bg-green-50/80 dark:bg-green-950/50',
  complete: 'text-blue-600 dark:text-blue-400 bg-blue-50/80 dark:bg-blue-950/50',
  'in-progress': 'text-amber-600 dark:text-amber-400 bg-amber-50/80 dark:bg-amber-950/50',
  archived: 'text-zinc-500 dark:text-zinc-500 bg-zinc-100/80 dark:bg-zinc-800/80',
};
---

<article class="group glass-card relative rounded-xl p-6">
  <div class="flex items-start justify-between gap-4 mb-3">
    <div class="flex-1 min-w-0">
      {client && (
        <p class="text-xs font-mono text-zinc-500 dark:text-zinc-500 mb-1 truncate">{client}</p>
      )}
      <h3 class="font-semibold text-zinc-900 dark:text-zinc-100 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors leading-snug">
        <a href={href} class="after:absolute after:inset-0 relative">
          {title}
        </a>
      </h3>
      {role && (
        <p class="text-sm text-zinc-500 dark:text-zinc-500 mt-0.5">{role}</p>
      )}
    </div>
    {date && (
      <span class="font-mono text-xs text-zinc-400 dark:text-zinc-600 shrink-0">{date}</span>
    )}
    {status && (
      <span class={`font-mono text-xs px-2 py-0.5 rounded-full shrink-0 ${statusColors[status] || statusColors.archived}`}>
        {status}
      </span>
    )}
  </div>

  <p class="text-sm text-zinc-600 dark:text-zinc-400 leading-relaxed mb-4">
    {description}
  </p>

  <div class="flex items-center justify-between gap-4">
    <!-- Stack tags -->
    <div class="flex flex-wrap gap-1.5">
      {stack.map((tag) => (
        <span class="stack-tag px-2 py-0.5 bg-zinc-100/80 dark:bg-zinc-800/60 text-zinc-600 dark:text-zinc-400 rounded">
          {tag}
        </span>
      ))}
    </div>

    <!-- External links (for projects) -->
    {(url || github) && (
      <div class="flex items-center gap-2 shrink-0">
        {github && (
          <a
            href={github}
            target="_blank"
            rel="noopener noreferrer"
            class="text-xs text-zinc-400 hover:text-zinc-700 dark:hover:text-zinc-200 transition-colors"
            aria-label={`GitHub: ${title}`}
            onclick="event.stopPropagation()"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
            </svg>
          </a>
        )}
        {url && (
          <a
            href={url}
            target="_blank"
            rel="noopener noreferrer"
            class="text-xs text-zinc-400 hover:text-zinc-700 dark:hover:text-zinc-200 transition-colors"
            aria-label={`Visit ${title}`}
            onclick="event.stopPropagation()"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
          </a>
        )}
      </div>
    )}
  </div>
</article>
