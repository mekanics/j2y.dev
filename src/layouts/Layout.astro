---
import Header from './Header.astro'

export interface Props {
	title: string
}

const { title } = Astro.props
---

<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Astro description" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>{title}</title>
	</head>
	<body>
		<Header />

		<slot />

		<!-- <Noise /> -->
	</body>
</html>
<style is:global>
	@font-face {
		font-family: 'DistantGalaxy';
		src: url('/fonts/iAWriterDuoV.ttf') format('truetype');
		font-weight: normal;
		font-style: normal;
		font-display: swap;
	}

	:root {
		--accent-1: #f6f4f4;
		--accent-2: #252624;
		--accent-3: #434343;

		--gutter-h: 3vw;
		--gap: 40px;
	}

	* {
		box-sizing: border-box;
	}

	html {
		font-family: 'iA Writer Duo V', system-ui, sans-serif;
		background: var(--accent-1, #f6f4f4);
		color: var(--accent-2, #252624);
	}

	body {
		margin: 0;
	}

	@media (prefers-color-scheme: dark) {
		:root {
			--accent-1: #252624;
			--accent-2: #f6f4f4;
			--accent-3: #434343;
		}
	}
</style>
