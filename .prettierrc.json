{
	"arrowParens": "avoid",
	"bracketSameLine": true,
	"bracketSpacing": true,
	"singleQuote": true,
	"trailingComma": "all",
	"tabWidth": 4,
	"printWidth": 120,
	"useTabs": true,
	"semi": false,
	"endOfLine": "lf",
	"overrides": [
		{
			"files": "*.yml",
			"options": {
				"tabWidth": 2,
				"useTabs": false
			}
		},
		{
			"files": "*.graphql",
			"options": {
				"tabWidth": 2,
				"useTabs": false
			}
		}
	]
}
